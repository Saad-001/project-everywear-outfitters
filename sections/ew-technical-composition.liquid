        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Ultra-dense weave provides structural silhouette stability and enhanced thermal regulation."
        },
        {
          "type": "html",
          "id": "icon_svg",
          "label": "Icon SVG (optional)",

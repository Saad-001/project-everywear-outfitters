<!-- EveryWear: Instagram / Social Feed -->
<section class="py-24 px-8 max-w-screen-2xl mx-auto overflow-hidden">

  <!-- Header -->
  <div class="ew-reveal mb-12">
    <h2 class="font-label text-sm uppercase tracking-[0.4em] font-bold" style="color: #9c3f00;">
      {{ section.settings.hashtag }}
    </h2>
    {%- if section.settings.heading != blank -%}
      <p class="font-headline font-black text-3xl uppercase tracking-tighter mt-2" style="color: #1a1c1c;">
        {{ section.settings.heading }}
      </p>
    {%- endif -%}
  </div>

  <!-- Photo grid -->
  <div class="grid grid-cols-2 md:grid-cols-6 gap-4 ew-stagger">
    {%- for block in section.blocks -%}
      <div
        class="ew-reveal-scale aspect-square overflow-hidden group"
        style="transition-delay: {{ forloop.index0 | times: 60 }}ms;"
        {{ block.shopify_attributes }}
      >
        {%- if block.settings.link != blank -%}
          <a href="{{ block.settings.link }}" target="_blank" rel="noopener" class="block w-full h-full relative">
        {%- endif -%}

        {%- if block.settings.image != blank -%}
          <img
            src="{{ block.settings.image | image_url: width: 500 }}"
            alt="{{ block.settings.image.alt | default: section.settings.hashtag | escape }}"
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
            loading="lazy"
            width="{{ block.settings.image.width }}"
            height="{{ block.settings.image.height }}"
          >
          <!-- Instagram hover overlay -->
          <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-400" style="background-color: rgba(156,63,0,0.55);">
            <span class="material-symbols-outlined text-white" style="font-size: 2rem;">open_in_new</span>
          </div>
        {%- else -%}
          <div class="w-full h-full flex items-center justify-center" style="background-color: #efeeed;">
            <span class="material-symbols-outlined" style="color: #8c7166; font-size: 2.5rem;">photo_camera</span>
          </div>
        {%- endif -%}

        {%- if block.settings.link != blank -%}
          </a>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>

  <!-- CTA -->
  {%- if section.settings.cta_label != blank -%}
    <div class="ew-reveal text-center mt-10">
      <a
        href="{{ section.settings.cta_link }}"
        target="_blank"
        rel="noopener"
        class="ew-btn-shimmer font-headline font-bold uppercase text-sm tracking-widest py-3 px-10 inline-block border-2 transition-all duration-300"
        style="border-color: #9c3f00; color: #9c3f00;"
        onmouseover="this.style.backgroundColor='#9c3f00'; this.style.color='#ffffff'; this.style.transform='translateY(-2px)';"
        onmouseout="this.style.backgroundColor=''; this.style.color='#9c3f00'; this.style.transform='';"
      >
        {{ section.settings.cta_label }}
      </a>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "EW Instagram Feed",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "hashtag",
      "label": "Hashtag / Section Label",
      "default": "#EveryWearInAction"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading (optional)"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA Button Label",
      "default": "Follow us on Instagram"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA Button Link"
    }
  ],
  "blocks": [
    {
      "type": "feed_image",
      "name": "Feed Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "EW Instagram Feed",
      "settings": { "hashtag": "#EveryWearInAction" },
      "blocks": [
        { "type": "feed_image" },
        { "type": "feed_image" },
        { "type": "feed_image" },
        { "type": "feed_image" },
        { "type": "feed_image" },
        { "type": "feed_image" }
      ]
    }
  ]
}
{% endschema %}

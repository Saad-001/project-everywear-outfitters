{%- liquid
  assign bg     = section.settings.color_scheme
  assign is_dark = false
  if bg == 'dark'
    assign is_dark = true
  endif
-%}

<style>
  #ew-ip-{{ section.id }} {
    --ip-bg:          {% if is_dark %}#1a1c1c{% else %}#faf9f9{% endif %};
    --ip-text:        {% if is_dark %}#faf9f9{% else %}#1a1c1c{% endif %};
    --ip-muted:       {% if is_dark %}rgba(250,249,249,0.45){% else %}rgba(26,28,28,0.45){% endif %};
    --ip-border:      {% if is_dark %}rgba(250,249,249,0.1){% else %}rgba(26,28,28,0.1){% endif %};
    --ip-accent:      #9c3f00;
    --ip-accent-warm: #ffb693;
    --ip-pad:         {{ section.settings.section_padding }}px;
  }

  #ew-ip-{{ section.id }} {
    background-color: var(--ip-bg);
    color: var(--ip-text);
    position: relative;
    overflow: hidden;
    padding: var(--ip-pad) 0;
  }

  /* Grain texture */
  #ew-ip-{{ section.id }}::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: url('https://www.transparenttextures.com/patterns/carbon-fibre.png');
    opacity: {% if is_dark %}0.06{% else %}0.03{% endif %};
    pointer-events: none;
    z-index: 0;
  }

  #ew-ip-{{ section.id }} .ip-inner {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Eyebrow */
  #ew-ip-{{ section.id }} .ip-eyebrow {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 3rem;
  }
  #ew-ip-{{ section.id }} .ip-eyebrow-line {
    flex: 0 0 48px;
    height: 1px;
    background-color: var(--ip-accent);
  }
  #ew-ip-{{ section.id }} .ip-eyebrow-text {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--ip-accent-warm);
  }

  /* Headline */
  #ew-ip-{{ section.id }} .ip-headline {
    font-family: 'Inter', sans-serif;
    font-size: clamp(4.5rem, 12vw, 9rem);
    font-weight: 900;
    line-height: 0.88;
    letter-spacing: -0.04em;
    text-transform: uppercase;
    color: var(--ip-text);
    text-align: center;
    margin-bottom: 2rem;
  }
  #ew-ip-{{ section.id }} .ip-headline em {
    font-style: normal;
    color: var(--ip-accent-warm);
  }

  /* Description */
  #ew-ip-{{ section.id }} .ip-description {
    font-family: 'Work Sans', sans-serif;
    font-size: clamp(0.9rem, 1.5vw, 1.05rem);
    line-height: 1.7;
    color: var(--ip-muted);
    text-align: center;
    max-width: 560px;
    margin: 0 auto 3rem;
  }

  /* CTA */
  #ew-ip-{{ section.id }} .ip-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--ip-bg);
    background-color: var(--ip-accent);
    padding: 0.9rem 2.2rem;
    border: 2px solid var(--ip-accent);
    transition: background 0.25s ease, color 0.25s ease;
    margin-bottom: 4rem;
  }
  #ew-ip-{{ section.id }} .ip-cta:hover {
    background-color: transparent;
    color: var(--ip-accent-warm);
  }

  /* Divider before stats */
  #ew-ip-{{ section.id }} .ip-divider {
    width: 100%;
    height: 1px;
    background: var(--ip-border);
    margin-bottom: 3rem;
  }

  /* Stats grid */
  #ew-ip-{{ section.id }} .ip-stats {
    display: grid;
    grid-template-columns: repeat({{ section.blocks.size | at_least: 1 }}, 1fr);
    gap: 0;
  }

  @media (max-width: 767px) {
    #ew-ip-{{ section.id }} .ip-stats {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 479px) {
    #ew-ip-{{ section.id }} .ip-stats {
      grid-template-columns: 1fr;
    }
  }

  #ew-ip-{{ section.id }} .ip-stat {
    padding: 1.5rem 2rem;
    text-align: center;
    border-left: 1px solid var(--ip-border);
  }
  #ew-ip-{{ section.id }} .ip-stat:first-child {
    border-left: none;
  }
  @media (max-width: 767px) {
    #ew-ip-{{ section.id }} .ip-stat:nth-child(2n+1) {
      border-left: none;
    }
  }

  #ew-ip-{{ section.id }} .ip-stat-number {
    font-family: 'Inter', sans-serif;
    font-size: clamp(3rem, 6vw, 4.5rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1;
    color: var(--ip-text);
    margin-bottom: 0.6rem;
  }
  #ew-ip-{{ section.id }} .ip-stat-number span {
    color: var(--ip-accent-warm);
  }
  #ew-ip-{{ section.id }} .ip-stat-label {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ip-muted);
    margin-bottom: 0.3rem;
  }
  #ew-ip-{{ section.id }} .ip-stat-sublabel {
    font-family: 'Work Sans', sans-serif;
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ip-accent-warm);
    opacity: 0.7;
  }

  /* Spec badge */
  #ew-ip-{{ section.id }} .ip-spec-badge {
    position: absolute;
    bottom: 1.5rem;
    right: 2rem;
    text-align: right;
    z-index: 1;
  }
  #ew-ip-{{ section.id }} .ip-spec-badge p {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 8px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ip-muted);
    line-height: 1.8;
    opacity: 0.5;
  }
</style>

<section id="ew-ip-{{ section.id }}" aria-label="{{ section.settings.heading_line_1 }} {{ section.settings.heading_line_2 }}">
  <div class="ip-inner">

    {%- if section.settings.eyebrow != blank -%}
      <div class="ip-eyebrow">
        <div class="ip-eyebrow-line"></div>
        <p class="ip-eyebrow-text">{{ section.settings.eyebrow }}</p>
        <div class="ip-eyebrow-line"></div>
      </div>
    {%- endif -%}

    <h2 class="ip-headline">
      {%- if section.settings.heading_line_1 != blank -%}
        {%- if section.settings.accent_line == 'line_1' -%}
          <em>{{ section.settings.heading_line_1 }}</em>
        {%- else -%}
          {{ section.settings.heading_line_1 }}
        {%- endif -%}
      {%- endif -%}
      {%- if section.settings.heading_line_2 != blank -%}
        <br>
        {%- if section.settings.accent_line == 'line_2' -%}
          <em>{{ section.settings.heading_line_2 }}</em>
        {%- else -%}
          {{ section.settings.heading_line_2 }}
        {%- endif -%}
      {%- endif -%}
    </h2>

    {%- if section.settings.description != blank -%}
      <p class="ip-description">{{ section.settings.description }}</p>
    {%- endif -%}

    {%- if section.settings.cta_label != blank and section.settings.cta_link != blank -%}
      <div style="text-align:center;">
        <a href="{{ section.settings.cta_link }}" class="ip-cta">
          {{ section.settings.cta_label }}
          <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true">
            <path d="M1 5h12M8 1l5 4-5 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="ip-divider"></div>
      <div class="ip-stats">
        {%- for block in section.blocks -%}
          <div class="ip-stat" {{ block.shopify_attributes }}>
            {%- if block.settings.stat_number != blank -%}
              <p class="ip-stat-number">
                {%- assign parts = block.settings.stat_number | split: '*' -%}
                {%- if parts.size > 1 -%}
                  {{ parts[0] }}<span>{{ parts[1] }}</span>{{ parts[2] }}
                {%- else -%}
                  {{ block.settings.stat_number }}
                {%- endif -%}
              </p>
            {%- endif -%}
            {%- if block.settings.stat_label != blank -%}
              <p class="ip-stat-label">{{ block.settings.stat_label }}</p>
            {%- endif -%}
            {%- if block.settings.stat_sublabel != blank -%}
              <p class="ip-stat-sublabel">{{ block.settings.stat_sublabel }}</p>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>

  {%- if section.settings.show_spec_badge -%}
    <div class="ip-spec-badge hidden lg:block">
      <p>
        {%- if section.settings.spec_line_1 != blank -%}{{ section.settings.spec_line_1 }}<br>{%- endif -%}
        {%- if section.settings.spec_line_2 != blank -%}{{ section.settings.spec_line_2 }}{%- endif -%}
      </p>
    </div>
  {%- endif -%}

</section>

{% schema %}
{
  "name": "Industrial Precision",
  "class": "industrial-precision-section",
  "settings": [
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Colour scheme",
      "options": [
        { "value": "dark", "label": "Dark (brand default)" },
        { "value": "light", "label": "Light" }
      ],
      "default": "dark"
    },
    {
      "type": "header",
      "content": "Eyebrow"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Engineered Workwear Standards // Est. 2012"
    },
    {
      "type": "header",
      "content": "Headline"
    },
    {
      "type": "text",
      "id": "heading_line_1",
      "label": "Headline — line 1",
      "default": "Industrial"
    },
    {
      "type": "text",
      "id": "heading_line_2",
      "label": "Headline — line 2",
      "default": "Precision"
    },
    {
      "type": "select",
      "id": "accent_line",
      "label": "Orange accent on",
      "info": "Wrap one line in the brand orange colour",
      "options": [
        { "value": "none",   "label": "None" },
        { "value": "line_1", "label": "Line 1" },
        { "value": "line_2", "label": "Line 2" }
      ],
      "default": "none"
    },
    {
      "type": "header",
      "content": "Body"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Every garment printed in-house on industrial-grade equipment. No outsourcing. No compromise. Just precision, at scale."
    },
    {
      "type": "header",
      "content": "Call to Action"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Shop All Products"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Spec Badge (bottom right)"
    },
    {
      "type": "checkbox",
      "id": "show_spec_badge",
      "label": "Show spec badge",
      "default": true
    },
    {
      "type": "text",
      "id": "spec_line_1",
      "label": "Spec line 1",
      "default": "Spec. Index: IP-2024"
    },
    {
      "type": "text",
      "id": "spec_line_2",
      "label": "Spec line 2",
      "default": "Verification: Confirmed"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "section_padding",
      "min": 40,
      "max": 220,
      "step": 10,
      "unit": "px",
      "label": "Section padding (top & bottom)",
      "default": 140
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        {
          "type": "text",
          "id": "stat_number",
          "label": "Number",
          "info": "Wrap a character in * to colour it orange. E.g. 50*K*+",
          "default": "50*K*+"
        },
        {
          "type": "text",
          "id": "stat_label",
          "label": "Label",
          "default": "Garments Printed"
        },
        {
          "type": "text",
          "id": "stat_sublabel",
          "label": "Sub-label",
          "default": "& counting"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Industrial Precision",
      "blocks": [
        {
          "type": "stat",
          "settings": {
            "stat_number": "10*+*",
            "stat_label": "Years in Business",
            "stat_sublabel": "Est. 2012"
          }
        },
        {
          "type": "stat",
          "settings": {
            "stat_number": "50*K*+",
            "stat_label": "Garments Printed",
            "stat_sublabel": "& counting"
          }
        },
        {
          "type": "stat",
          "settings": {
            "stat_number": "100*%*",
            "stat_label": "In-House Printing",
            "stat_sublabel": "No outsourcing"
          }
        },
        {
          "type": "stat",
          "settings": {
            "stat_number": "AUS*-*Wide",
            "stat_label": "Delivery",
            "stat_sublabel": "Fast turnaround"
          }
        }
      ]
    }
  ]
}
{% endschema %}
{% comment %}
  Section: EW Bulk Engineering
  Customizable via Shopify Theme Editor
{% endcomment %}

<section
  class="ew-bulk-eng"
  id="ew-bulk-eng-{{ section.id }}"
  style="
    --bg:          {{ section.settings.section_bg }};
    --stat-bg:     {{ section.settings.stat_bg }};
    --accent:      {{ section.settings.accent_color }};
    --heading-col: {{ section.settings.heading_color }};
    --body-col:    {{ section.settings.body_text_color }};
    --btn-bg:      {{ section.settings.btn_bg }};
    --btn-hover:   {{ section.settings.btn_hover_bg }};
    --btn-text:    {{ section.settings.btn_text_color }};
    --card-bg:     {{ section.settings.card_bg }};
  "
>
  <div class="ew-bulk-eng__inner page-width">
    <div class="ew-bulk-eng__card">

      <!-- Stat Panel -->
      <div class="ew-bulk-eng__stat">
        <span class="ew-bulk-eng__stat-number">{{ section.settings.stat_number }}</span>
        <span class="ew-bulk-eng__stat-label">{{ section.settings.stat_label }}</span>
      </div>

      <!-- Content Panel -->
      <div class="ew-bulk-eng__content">
        <h3 class="ew-bulk-eng__heading">{{ section.settings.heading }}</h3>
        {% if section.settings.description != blank %}
          <p class="ew-bulk-eng__description">{{ section.settings.description }}</p>
        {% endif %}
      </div>

      <!-- CTA Panel -->
      {% if section.settings.btn_label != blank %}
        <div class="ew-bulk-eng__cta">
          <a
            href="{{ section.settings.btn_link }}"
            class="ew-bulk-eng__btn"
          >
            <span>{{ section.settings.btn_label }}</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      {% endif %}

    </div>
  </div>
</section>

<style>
  #ew-bulk-eng-{{ section.id }} {
    background-color: var(--bg);
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    font-family: var(--font-body-family);
  }

  #ew-bulk-eng-{{ section.id }} .ew-bulk-eng__inner {
    max-width: var(--page-width);
    margin: 0 auto;
    /* padding: 0 1.5rem; */
  }

  #ew-bulk-eng-{{ section.id }} .ew-bulk-eng__card {
    display: flex;
    align-items: stretch;
    overflow: hidden;
    border: 1px solid rgba(26,28,28,0.08);
    background-color: var(--card-bg);
  }

  /* STAT PANEL */
  #ew-bulk-eng-{{ section.id }} .ew-bulk-eng__stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background-color: var(--stat-bg);
    padding: 40px 36px;
    text-align: center;
    flex-shrink: 0;
    min-width: 160px;
  }

  #ew-bulk-eng-{{ section.id }} .ew-bulk-eng__stat-number {
    font-family: var(--font-heading-family);
    font-size: clamp(44px, 6vw, 72px);
    font-weight: 900;
    line-height: 1;
    letter-spacing: -0.02em;
    color: #faf9f9;
    text-transform: uppercase;
  }

  #ew-bulk-eng-{{ section.id }} .ew-bulk-eng__stat-label {
    font-family: var(--font-body-family);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-top: 8px;
  }

  /* CONTENT PANEL */
  #ew-bulk-eng-{{ section.id }} .ew-bulk-eng__content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 40px 48px;
  }

  #ew-bulk-eng-{{ section.id }} .ew-bulk-eng__heading {
    font-family: var(--font-heading-family);
    font-size: clamp(26px, 3.5vw, 42px);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 1;
    color: var(--heading-col);
    margin: 0 0 16px;
  }

  #ew-bulk-eng-{{ section.id }} .ew-bulk-eng__description {
    font-family: var(--font-body-family);
    font-size: clamp(13px, 1.3vw, 15px);
    line-height: 1.65;
    color: var(--body-col);
    margin: 0;
    max-width: 520px;
  }

  /* CTA PANEL */
  #ew-bulk-eng-{{ section.id }} .ew-bulk-eng__cta {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 36px;
    flex-shrink: 0;
    background-color: var(--bg);
  }

  #ew-bulk-eng-{{ section.id }} .ew-bulk-eng__btn {
    display: inline-flex;
    align-items: center;
    gap: 20px;
    background-color: var(--btn-bg);
    color: var(--btn-text);
    padding: 18px 28px;
    font-family: var(--font-body-family);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    text-decoration: none;
    transition: background-color 0.25s ease, transform 0.25s ease;
    white-space: nowrap;
  }

  #ew-bulk-eng-{{ section.id }} .ew-bulk-eng__btn:hover {
    background-color: var(--btn-hover);
    transform: translateY(-2px);
  }

  #ew-bulk-eng-{{ section.id }} .ew-bulk-eng__btn svg {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    transition: transform 0.25s ease;
  }

  #ew-bulk-eng-{{ section.id }} .ew-bulk-eng__btn:hover svg {
    transform: translateX(4px);
  }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    #ew-bulk-eng-{{ section.id }} .ew-bulk-eng__card {
      flex-direction: column;
    }
    #ew-bulk-eng-{{ section.id }} .ew-bulk-eng__stat {
      padding: 32px 24px;
      min-width: unset;
      flex-direction: row;
      gap: 16px;
      text-align: left;
    }
    #ew-bulk-eng-{{ section.id }} .ew-bulk-eng__stat-label {
      margin-top: 0;
    }
    #ew-bulk-eng-{{ section.id }} .ew-bulk-eng__content {
      padding: 32px 28px 24px;
    }
    #ew-bulk-eng-{{ section.id }} .ew-bulk-eng__description {
      max-width: 100%;
    }
    #ew-bulk-eng-{{ section.id }} .ew-bulk-eng__cta {
      padding: 24px 28px 32px;
      justify-content: flex-start;
    }
  }

  @media (max-width: 480px) {
    #ew-bulk-eng-{{ section.id }} .ew-bulk-eng__btn {
      width: 100%;
      justify-content: space-between;
    }
  }
</style>

{% schema %}
{
  "name": "EW Bulk Engineering",
  "tag": "section",
  "class": "ew-bulk-engineering-section",
  "settings": [
    {
      "type": "header",
      "content": "Stat Block"
    },
    {
      "type": "text",
      "id": "stat_number",
      "label": "Stat Number",
      "default": "100+"
    },
    {
      "type": "text",
      "id": "stat_label",
      "label": "Stat Label",
      "default": "Items"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Bulk Engineering"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Equip your entire workforce with precision-crafted uniforms. Tiered pricing available for orders over 100 units. Our team handles large-scale production with the same industrial precision as our single-item prints."
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button Label",
      "default": "Request a Quote"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Section Background",
      "default": "#faf9f9"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "stat_bg",
      "label": "Stat Panel Background",
      "default": "#1a1c1c"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color (Stat Label)",
      "default": "#ffb693"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#1a1c1c"
    },
    {
      "type": "color",
      "id": "body_text_color",
      "label": "Body Text Color",
      "default": "#7a7d7d"
    },
    {
      "type": "color",
      "id": "btn_bg",
      "label": "Button Background",
      "default": "#1a1c1c"
    },
    {
      "type": "color",
      "id": "btn_hover_bg",
      "label": "Button Hover Background",
      "default": "#9c3f00"
    },
    {
      "type": "color",
      "id": "btn_text_color",
      "label": "Button Text Color",
      "default": "#faf9f9"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "EW Bulk Engineering",
      "settings": {
        "stat_number": "100+",
        "stat_label": "Items",
        "heading": "Bulk Engineering",
        "description": "Equip your entire workforce with precision-crafted uniforms. Tiered pricing available for orders over 100 units. Our team handles large-scale production with the same industrial precision as our single-item prints.",
        "btn_label": "Request a Quote"
      }
    }
  ]
}
{% endschema %}
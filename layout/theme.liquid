              "on-primary": "#ffffff",
              "primary-fixed-dim": "#ffb693",
              "outline": "#8c7166",
              "on-background": "#1a1c1c",
              "tertiary": "#5d5c5b",
              "surface-container-highest": "#e3e2e2",
              "inverse-surface": "#2f3131",
              "surface-container-high": "#e9e8e8",
              "on-error": "#ffffff",
              "secondary-container": "#e2e2e2",
